# Database Configuration
MYSQL_ROOT_PASSWORD=your-secure-root-password-here
MYSQL_DATABASE=danteplanner
MYSQL_USER=danteplanner
MYSQL_PASSWORD=your-secure-database-password-here

# JWT Configuration
# Generate with: openssl rand -base64 48
JWT_SECRET=your-256-bit-secret-key-change-this-in-production

# Google OAuth Configuration
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/auth/callback/google

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost

# Trusted Proxy Configuration
# REQUIRED for Docker: Include Docker bridge network (172.18.0.0/16)
# For production with Cloudflare, add Cloudflare IP ranges
# Example: TRUSTED_PROXY_IPS=172.18.0.0/16,103.21.244.0/22,103.22.200.0/22
TRUSTED_PROXY_IPS=172.18.0.0/16
