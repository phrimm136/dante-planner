# Copy to terraform.tfvars (gitignored) and fill with YOUR account's real values.
# Do NOT commit terraform.tfvars — it contains account-specific identifiers.

vpc_id                = "vpc-xxxxxxxxxxxxxxxxx"
db_subnet_ids         = ["subnet-aaaaaaaaaaaaaaaaa", "subnet-bbbbbbbbbbbbbbbbb"] # >=2 AZs
availability_zone     = "us-west-2a"   # MUST equal the EC2 instance's AZ
ec2_security_group_id = "sg-xxxxxxxxxxxxxxxxx"
engine_version        = "8.0.40"       # REQUIRED: pin to >= source @@version (runbook 0.2)

# Optional overrides (defaults are sensible):
# instance_class     = "db.t4g.micro"
# ca_cert_identifier = "rds-ca-rsa2048-g1"  # set to the live instance's current CA
# db_name            = "danteplanner"

# Set true ONLY during the migration window (Zone 0), back to false at decommission (Zone 4):
enable_replication_ingress = false

# Set this to the source's captured @@sql_mode (runbook step 0.2) before applying:
# sql_mode = "..."
