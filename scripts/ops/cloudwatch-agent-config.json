{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "metrics": {
    "namespace": "DantePlanner",
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_user", "cpu_usage_system"],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used_percent", "mem_available", "mem_used"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["disk_used_percent", "disk_free", "disk_used"],
        "metrics_collection_interval": 60,
        "resources": ["/"]
      },
      "diskio": {
        "measurement": ["reads", "writes", "read_bytes", "write_bytes"],
        "metrics_collection_interval": 60,
        "resources": ["*"]
      },
      "net": {
        "measurement": ["bytes_sent", "bytes_recv", "packets_sent", "packets_recv"],
        "metrics_collection_interval": 60,
        "resources": ["ens5"]
      },
      "procstat": [
        {
          "exe": "java",
          "measurement": ["memory_rss", "cpu_usage", "num_threads", "num_fds"],
          "metrics_collection_interval": 60
        },
        {
          "exe": "mysqld",
          "measurement": ["memory_rss", "cpu_usage", "num_threads", "num_fds"],
          "metrics_collection_interval": 60
        },
        {
          "exe": "nginx",
          "measurement": ["memory_rss", "cpu_usage", "num_threads"],
          "metrics_collection_interval": 60
        }
      ]
    },
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    }
  },
  "logs": {
    "metrics_collected": {
      "prometheus": {
        "log_group_name": "/danteplanner/prometheus",
        "prometheus_config_path": "/opt/aws/amazon-cloudwatch-agent/etc/prometheus.yaml",
        "emf_processor": {
          "metric_declaration_dedup": true,
          "metric_namespace": "DantePlanner",
          "metric_unit": {
            "jvm_memory_used_bytes": "Bytes",
            "jvm_memory_committed_bytes": "Bytes",
            "jvm_memory_max_bytes": "Bytes",
            "jvm_gc_pause_seconds_max": "Seconds"
          },
          "metric_declaration": [
            {
              "source_labels": ["job"],
              "label_matcher": "^backend$",
              "dimensions": [["area", "id"]],
              "metric_selectors": ["^jvm_memory_(used|committed|max)_bytes$"]
            },
            {
              "source_labels": ["job"],
              "label_matcher": "^backend$",
              "dimensions": [["action", "cause"]],
              "metric_selectors": ["^jvm_gc_pause_seconds_(max|count|sum)$"]
            },
            {
              "source_labels": ["job"],
              "label_matcher": "^backend$",
              "dimensions": [["pool"]],
              "metric_selectors": ["^hikaricp_connections_(active|pending)$"]
            }
          ]
        }
      }
    },
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/danteplanner-backup.log",
            "log_group_name": "/danteplanner/backup",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/cloudflare-ip-update.log",
            "log_group_name": "/danteplanner/cloudflare-ip",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/danteplanner-cw-export.log",
            "log_group_name": "/danteplanner/cw-export",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/danteplanner-query-stats.log",
            "log_group_name": "/danteplanner/query-stats",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
