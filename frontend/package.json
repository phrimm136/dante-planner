{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsx scripts/generate-sitemap.ts && tsc -b && ROLLDOWN_MAX_BLOCKING_THREADS=512 vite build",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "typecheck": "tsc -b",
    "lint": "oxlint --type-aware --tsconfig tsconfig.app.json --deny-warnings src",
    "lint:advisory": "oxlint -c .oxlintrc.jsplugins.json src",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
