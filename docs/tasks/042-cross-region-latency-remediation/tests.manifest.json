  "decisions": [
    {
      "id": "D1",
      "text": "Read endpoints are @Transactional(readOnly=true); writes extracted — readOnly is the replica-routing signal",
      "enforcement": "review-only"
    },
    {
      "id": "D2",
      "text": "Constraint-over-lock: PK/unique-key-owned invariants use INSERT IGNORE / handled violation, not PESSIMISTIC_WRITE; CLAUDE.md check-then-act line amended",
      "enforcement": "review-only"
    },
    {
      "id": "D5",
      "text": "No executors/@Async anywhere; async = per-pod buffer + @Scheduled flush (never ShedLocked) or AFTER_COMMIT listeners",
      "enforcement": "review-only"
    },
    {
      "id": "D15",
      "text": "Counter columns updatable=false until planner_stats cutover completes",
      "enforcement": "review-only"
    },
    {
      "id": "D16",
      "text": "planner_stats dual-write unconditional; reads flag-gated via overlay ConfigMap env PLANNER_STATS_READS_ENABLED",
      "enforcement": "review-only"
    },
    {
      "id": "D19",
      "text": "idx_v0NN_published_recent carries taken_down_at: (published, deleted_at, taken_down_at, created_at, category); DROP list unchanged (idx_v006_published_views, idx_published); takenDownAt IS NULL predicate retained in all published-read queries; category-filtered count served by idx_published_category, not required covering",
      "enforcement": "task-tier EXPLAIN probe against Flyway-migrated MySQL: page query no filesort, no-category count Using index"
    },
    {
      "id": "D20",
      "text": "Stats cutover gate is LEFT JOIN + s.planner_id IS NULL predicate (missing stats row = dirty); planner creation inserts a zeroed planner_stats row in the creation transaction at both PlannerCommandService sites; backfill is unfiltered INSERT..SELECT over all planners",
      "enforcement": "PlannerStatsDualWriteIT#incrementAdvancesBothStores red batch pinned to a seeded legacy planner with no stats row"
    }
  ],
