{
    "version": "3.0",
    "description": "Skill activation triggers. v3: removed phantom fe-*/be-* entries (no SKILL.md), tightened overly broad keywords, changed enforcement to suggest.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    ".claude/skills/**/*",
                    ".claude/hooks/**/*",
                    ".claude/settings.json"
                ]
            }
        },
        "route-tester": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Testing authenticated API routes with JWT cookie-based auth",
            "promptTriggers": {
                "keywords": [
                    "test route",
                    "test endpoint",
                    "test API",
                    "route testing",
                    "API testing",
                    "authenticated route",
                    "JWT testing",
                    "cookie auth",
                    "test with auth"
                ],
                "intentPatterns": [
                    "(test|debug|verify).*?(route|endpoint|API)",
                    "(how to|how do I).*?test.*?(route|endpoint|API)",
                    "test.*?(authenticated|auth|JWT|cookie)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/routes/**/*.ts",
                    "**/test-*.js",
                    "**/test-*.ts"
                ],
                "contentPatterns": [
                    "router\\.(get|post|put|delete|patch)",
                    "app\\.(get|post|put|delete|patch)"
                ]
            }
        },
        "error-tracking": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Sentry error tracking and performance monitoring patterns",
            "promptTriggers": {
                "keywords": [
                    "sentry",
                    "error tracking",
                    "captureException",
                    "performance tracking"
                ],
                "intentPatterns": [
                    "(add|create|implement|setup).*?(sentry|error tracking)",
                    "(how to|best practice).*?(sentry|monitoring)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/instrument.ts",
                    "**/sentry*.ts",
                    "backend/**/exception/**/*.java"
                ],
                "contentPatterns": [
                    "@sentry",
                    "Sentry\\.",
                    "captureException",
                    "captureMessage"
                ]
            }
        },
        "web-research-specialist": {
            "type": "agent",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Community workaround research - use instead of WebSearch for debugging issues",
            "promptTriggers": {
                "keywords": [
                    "workaround",
                    "known issue",
                    "community solution",
                    "github issue",
                    "stackoverflow"
                ],
                "intentPatterns": [
                    "(find|search|look for).*?(workaround|fix|solution|issue)",
                    "(anyone|others).*?(solved|fixed|encountered)",
                    "is this a (bug|known issue)"
                ]
            }
        },
        "code-review-orchestrator": {
            "type": "agent",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-reviewer that launches security, performance, reliability, and consistency reviewers in parallel",
            "promptTriggers": {
                "keywords": [
                    "code review",
                    "check my code",
                    "find bugs",
                    "review my changes"
                ],
                "intentPatterns": [
                    "(review|check|examine).*?(code|component|implementation|changes)",
                    "(find|look for|any).*?(bugs|issues|problems)",
                    "what('s| is) wrong with"
                ]
            }
        },
        "add-announcement": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Add a new announcement to all 5 JSON files with auto-translation",
            "promptTriggers": {
                "keywords": ["add announcement", "new announcement", "write announcement", "공지"],
                "intentPatterns": [
                    "(add|write|create|post).*?announcement",
                    "announcement.*?(add|write|create|new)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "static/data/announcements*.json"
                ]
            }
        },
        "commit-message": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Commit message style guide following Spring Framework convention",
            "promptTriggers": {
                "keywords": [
                    "commit",
                    "git commit",
                    "commit message"
                ],
                "intentPatterns": [
                    "(create|make|write|do).*?commit",
                    "commit.*?(change|code|work|fix|feat)"
                ]
            }
        },
        "findings-sync": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Synchronize patterns from findings.md to skill documentation",
            "promptTriggers": {
                "keywords": [
                    "findings sync",
                    "sync findings",
                    "update specs",
                    "consolidate learnings"
                ],
                "intentPatterns": [
                    "(sync|update|consolidate).*?(findings|learnings|patterns)",
                    "(findings|learnings).*?(to|into).*?(skills|specs|documentation)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "docs/**/findings.md"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution"
        },
        "v3_changelog": "Removed 9 phantom entries (fe-component, fe-data, fe-routing, fe-testing, be-controller, be-service, be-security, be-async, be-testing, be-config) — no SKILL.md existed. Changed all enforcement to suggest. Tightened keywords: removed 'hook', 'review', 'error handling', 'exception', 'validation', 'UI', 'component' and other overly broad terms that caused false-positive matches."
    }
}
